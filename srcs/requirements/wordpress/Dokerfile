#utilizzo immagine debian buster
FROM debian:buster
#aggiorno i pacchetti e scarico (PHP7.3 ,il modulo MYSQL, PHP-FPM e il client MARIADB)
#scarico da github uno strumento di riga di comando
#rendo eseguibile il file e lo sposto cosi da renderlo eseguibile globalmente
#rimuovo wget perche non serve piu
#elimino file residui inutili
RUN apt-get update -y && \
apt-get install -y \
        php7.3 \
        php-mysql \
        php-fpm \
        mariadb-client\
        wget && \
        wget https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar && \
        chmod +x wp-cli.phar /usr/local/bin/wp && \
        apt remove -y wget && \
        apt-get clean && \
        rm -rf /var/lib/apt/lists/*
#scarico WORDPRESS
RUN wp core download --path=/usr/src/wordpress --allw-root
# Copiare il file di configurazione PHP-FPM
COPY www.conf /etc/php/7.3/fpm/pool.f/www.conf
# Impostare permessi sicuri per www.conf
RUN chmod 664 /etc/php7.3/fpm/pool.d/www.conf
# Copiare lo script di setup di WordPress
COPY wp_setup.sh /
# Definire il volume per i dati persistenti di WordPress
VOLUME [ "/var/www/" ]
#espongo la porta del PHP-FPM
EXPOSE 9000
# Eseguo lo script di setup di WordPress all'avvio del container senza bash
CMD ["/wp_setup.sh"]